# Copy this file to: android/keystore.properties (after `npx expo prebuild --platform android`)
# Paths are relative to the android/ folder. Put your .jks next to android/ or use a subfolder.
#
# Create a keystore once (example — use your own passwords and alias):
#   keytool -genkeypair -v -storetype JKS -keyalg RSA -keysize 2048 -validity 10000 ^
#     -alias fidely-upload -keystore android/fidely-upload.jks
#
# Use the SAME upload key that Google Play Console expects (SHA1), or request an upload key reset.

storeFile=fidely-upload.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=fidely-upload
keyPassword=YOUR_KEY_PASSWORD
