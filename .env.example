# Same port as fidely-back PORT
EXPO_PUBLIC_API_PORT=3002

# Physical device / Expo Go: your PC IPv4 (ipconfig → e.g. 192.168.x.x). Comment out for Android emulator-only.
EXPO_PUBLIC_API_URL=http://192.168.100.27:3002

# FCM: add google-services.json (Android) and GoogleService-Info.plist (iOS) to the project root, then set
# expo.android.googleServicesFile / expo.ios.googleServicesFile in app.json (see Firebase Console).
