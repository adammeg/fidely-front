# Same port as fidely-back PORT
EXPO_PUBLIC_API_PORT=3002

# Physical device / Expo Go: your PC IPv4 (ipconfig → e.g. 192.168.x.x). Comment out for Android emulator-only.
EXPO_PUBLIC_API_URL=https://fidely-back.onrender.com

# FCM: `google-services.json` must exist for Android native builds (see app.json → android.googleServicesFile).
# EAS Build only uploads files tracked by git. Either:
#   A) Commit `google-services.json` to git, or
#   B) Create an EAS file secret named `GOOGLE_SERVICES_JSON` (see app.config.js), then rebuild.
#
# Play Store package is `com.Fidely` (see app.json android.package). In Firebase Console, add an Android
# app with that exact package name and download `google-services.json` again so FCM stays valid.
